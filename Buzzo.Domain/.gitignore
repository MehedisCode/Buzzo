## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Rr]elease/
x64/
x86/
[Bb]in/
[Oo]bj/
[Ll]og/

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# Rider
.idea/

# VS Code
.vscode/

# Visual Studio Code Workspace
*.code-workspace

# Files built by Visual Studio
*.VisualState.xml
TestResult.xml
build/
bld/

# NCrunch
*.ncrunch*
.*crunch*.local.xml

# Coverlet
coverage*.json
coverage*.xml

# BenchmarkDotNet
BenchmarkDotNet.Artifacts/

# Publish output
publish/
wwwroot/dist/

# Dotnet core
project.lock.json
project.fragment.lock.json
artifacts/

# ASP.NET Core
appsettings.Development.json

# Secrets
secrets.json
*.secret.json

# Azure
*.azurePubxml
*.publishproj

# IIS Express
.vs/
iisexpress/
*.pfx

# Logs
*.log

# OS generated files
.DS_Store
Thumbs.db

# Node (if using frontend tooling)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Package files
*.nupkg
*.snupkg

# Resharper
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# StyleCop
StyleCopReport.xml

# Others
*.cache
*.dbmdl
*.bak
*.swp